<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>7group — Inteligencia Artificial para tu Operación</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a0a;
      --white: #f5f5f5;
      --gray: #6b6b6b;
      --light: #e8e8e8;
      --cyan: #5ee7f7;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background: var(--white);
      color: var(--black);
      line-height: 1.6;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      padding: 24px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 100;
      transition: background 0.4s, border-color 0.4s;
    }

    nav.scrolled {
      background: rgba(10,10,10,0.88);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .logo {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: #fff;
      text-decoration: none;
    }

    .logo span { color: var(--cyan); }

    nav ul {
      list-style: none;
      display: flex;
      gap: 40px;
    }

    nav a {
      text-decoration: none;
      color: rgba(255,255,255,0.65);
      font-size: 14px;
      letter-spacing: 0.3px;
      transition: color 0.2s;
    }

    nav a:hover { color: #fff; }

    /* HERO */
    .hero-wrapper {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background: url('ciudad-datos.webp') center center / cover no-repeat;
      transform: scale(1.04);
      transition: transform 8s ease-out;
    }

    .hero-bg.loaded { transform: scale(1); }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        105deg,
        rgba(0,0,0,0.82) 0%,
        rgba(0,0,0,0.55) 55%,
        rgba(0,0,0,0.15) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 120px 48px 80px;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-tag {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 28px;
    }

    .hero-content h1 {
      font-size: clamp(44px, 6.5vw, 88px);
      font-weight: 700;
      line-height: 1.02;
      letter-spacing: -2.5px;
      max-width: 760px;
      margin-bottom: 28px;
      color: #fff;
    }

    .hero-content h1 em {
      font-style: normal;
      color: rgba(255,255,255,0.35);
    }

    .hero-content > p {
      font-size: 17px;
      color: rgba(255,255,255,0.6);
      max-width: 480px;
      line-height: 1.75;
      margin-bottom: 48px;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .btn-primary {
      background: #fff;
      color: var(--black);
      text-decoration: none;
      padding: 16px 32px;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.3px;
      border: 2px solid #fff;
      transition: background 0.2s, color 0.2s;
    }

    .btn-primary:hover {
      background: transparent;
      color: #fff;
    }

    .cta-link {
      font-size: 14px;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }

    .cta-link:hover { color: #fff; border-color: #fff; }

    /* SCROLL INDICATOR */
    .scroll-hint {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0.4;
    }

    .scroll-hint span {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #fff;
    }

    .scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, #fff, transparent);
      animation: scrollline 2s ease-in-out infinite;
    }

    @keyframes scrollline {
      0%, 100% { opacity: 0.4; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(0.6); }
    }

    /* DIVIDER */
    .divider {
      border: none;
      border-top: 1px solid var(--light);
      margin: 0 48px;
    }

    /* SECTION BASE */
    section {
      padding: 100px 48px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 11px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 48px;
    }

    /* PROBLEMA */
    .problema h2 {
      font-size: clamp(28px, 4vw, 48px);
      font-weight: 600;
      letter-spacing: -1px;
      line-height: 1.2;
      max-width: 700px;
      margin-bottom: 24px;
    }

    .problema p {
      font-size: 16px;
      color: var(--gray);
      max-width: 520px;
      line-height: 1.8;
    }

    /* IMAGE BREAK — transicion */
    .image-break {
      width: 100%;
      height: 520px;
      overflow: hidden;
      position: relative;
    }

    .image-break img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      filter: brightness(0.95);
    }

    .image-break-caption {
      position: absolute;
      bottom: 28px;
      right: 36px;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }

    /* SOLUCIONES */
    .soluciones-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--light);
      border: 1px solid var(--light);
    }

    .solucion-card {
      background: var(--white);
      padding: 48px 40px;
      transition: background 0.2s;
    }

    .solucion-card:hover { background: #efefef; }

    .card-num {
      font-size: 11px;
      color: var(--gray);
      letter-spacing: 2px;
      margin-bottom: 24px;
    }

    .solucion-card h3 {
      font-size: 21px;
      font-weight: 600;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
    }

    .solucion-card p {
      font-size: 15px;
      color: var(--gray);
      line-height: 1.75;
    }

    /* NOSOTROS */
    .nosotros-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      align-items: stretch;
      border: 1px solid var(--light);
    }

    .nosotros-text {
      padding: 64px 56px;
      border-right: 1px solid var(--light);
    }

    .nosotros h2 {
      font-size: clamp(26px, 3.5vw, 40px);
      font-weight: 600;
      letter-spacing: -1px;
      line-height: 1.2;
      margin-bottom: 20px;
    }

    .nosotros p {
      font-size: 16px;
      color: var(--gray);
      line-height: 1.8;
      margin-bottom: 16px;
    }

    .nosotros-image {
      position: relative;
      overflow: hidden;
      min-height: 460px;
    }

    .nosotros-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      transition: transform 0.6s ease;
    }

    .nosotros-image:hover img { transform: scale(1.03); }

    /* STATS BAR */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid var(--light);
      border-top: none;
    }

    .stat-item {
      padding: 40px 36px;
      border-right: 1px solid var(--light);
    }

    .stat-item:last-child { border-right: none; }

    .stat-item strong {
      display: block;
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -2px;
      line-height: 1;
      margin-bottom: 8px;
    }

    .stat-item span {
      font-size: 13px;
      color: var(--gray);
      line-height: 1.5;
    }

    /* CTA FINAL */
    .cta-final {
      text-align: center;
      padding: 120px 48px;
      border-top: 1px solid var(--light);
    }

    .cta-final h2 {
      font-size: clamp(32px, 5vw, 64px);
      font-weight: 700;
      letter-spacing: -2px;
      line-height: 1.1;
      max-width: 600px;
      margin: 0 auto 16px;
    }

    .cta-final > p {
      color: var(--gray);
      font-size: 16px;
      margin-bottom: 40px;
    }

    /* WHATSAPP ICON */
    .wa-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      text-decoration: none;
      color: var(--black);
      transition: opacity 0.2s;
    }

    .wa-icon:hover { opacity: 0.35; }

    .wa-icon svg { width: 28px; height: 28px; }

    /* FOOTER */
    footer {
      padding: 32px 48px;
      border-top: 1px solid var(--light);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p { font-size: 13px; color: var(--gray); }

    footer a {
      font-size: 13px;
      color: var(--gray);
      text-decoration: none;
      transition: color 0.2s;
    }

    footer a:hover { color: var(--black); }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      nav { padding: 20px 24px; }
      nav ul { display: none; }
      .hero-content { padding: 100px 24px 60px; }
      section { padding: 72px 24px; }
      .divider { margin: 0 24px; }
      .image-break { height: 280px; }
      .soluciones-grid { grid-template-columns: 1fr; }
      .nosotros-inner { grid-template-columns: 1fr; }
      .nosotros-text { border-right: none; border-bottom: 1px solid var(--light); padding: 48px 32px; }
      .nosotros-image { min-height: 280px; }
      .stats-bar { grid-template-columns: 1fr; }
      .stat-item { border-right: none; border-bottom: 1px solid var(--light); }
      .cta-final { padding: 80px 24px; }
      footer { padding: 24px; flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav id="nav">
