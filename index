    </div>
    <div class="stats-bar">
      <div class="stat-item">
        <strong>4+</strong>
        <span>Soluciones probadas en producción real</span>
      </div>
      <div class="stat-item">
        <strong>100%</strong>
        <span>Construido y validado en operación propia</span>
      </div>
      <div class="stat-item">
        <strong>0</strong>
        <span>Promesas sin evidencia. Todo lo que ofrecemos, ya lo vivimos.</span>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
